{
  "name": "@enthropicdata/ah-ha-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Ah-Ha \u2014 exposes your Spaces, Board, Trail, Note, and List as AI tools for Claude Desktop, Cursor, and any MCP client",
  "type": "module",
  "bin": {
    "ah-ha-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist --dts",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ah-ha",
    "claude",
    "ai",
    "productivity",
    "kanban",
    "trail",
    "adhd",
    "personal-knowledge"
  ],
  "author": "Enthropic Data LLC",
  "license": "MIT",
  "homepage": "https://ah-ha.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/sohocs509/ah-ha.git",
    "directory": "mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}